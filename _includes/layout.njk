<!doctype html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>
    {{ title + " - Reino Eterno Online" if title else "Reino Eterno Online" }}
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Hanken+Grotesk:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/assets/styles.css" />
</head>

<body>
  <header class="site-nav">
    <div class="site-nav__inner">
      <a href="/" class="brand">
        <img class="brand-logo" src="/assets/reinoeterno-logo.png" alt="" width="36" height="36" />
        <span class="brand-name">Reino&nbsp;Eterno</span>
      </a>
      <nav class="nav-links">
        <a href="/#publicacoes">Publicações</a><span class="nav-sep">/</span>
        <a href="/#apps">Apps</a><span class="nav-sep">/</span>
        <a href="/#notas" class="is-current">Notas&nbsp;de&nbsp;Estudo</a>
      </nav>
    </div>
  </header>

  <main class="container">
    {%- if page.url == "/" -%}

    <!-- HERO -->
    <section id="top" class="hero">
      <div class="hero__title">
        <div class="hero-eyebrow">EST. — Soli Deo Gloria</div>
        <h1>Um arquivo do<br />Reino que<br />não passa.</h1>
      </div>
      <div class="hero__lede">
        <p>Escritos, traduções e estudo bíblico reunidos num só lugar.
          <span class="i muted-3">Writing, translation, and Bible study notes — gathered in one place.</span>
        </p>
        <div class="cta">
          <a href="/#notas" class="cta-btn cta-btn--solid">Ler as notas →</a>
          <a href="#publicacoes" class="cta-btn cta-btn--ghost">Publicações</a>
        </div>
      </div>
    </section>

    <!-- PROSE INTRO (real index.md content) -->
    {%- if content -%}
    <section class="home-prose">
      <article class="prose">{{ content | safe }}</article>
    </section>
    {%- endif -%}

    <!-- NOTAS DE ESTUDO -->
    <section id="notas" class="notas">
      <div class="notas-band">
        <span class="notas-band__title">Notas de Estudo</span>
        {%- set notasCount = notasTags | length -%}
        <span class="notas-band__num">{% if notasCount < 10 %}0{% endif %}{{ notasCount }} / Study Notes</span>
      </div>
      <div class="notas-intro">
        <p>Estudos verso a verso e ensaios sobre as doutrinas que estruturam a esperança cristã.
          <span class="i muted-3">The heart of this archive.</span>
        </p>
      </div>
      <div class="notas-grid">
        {%- for n in notasTags -%}
        {%- set count = collections.tagMap[n.slug] | length -%}
        <a href="/90._assets/tags/{{ n.slug }}/" class="note-card">
          <span class="note-card__num">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
          <span>
            <span class="note-card__pt">{{ n.pt }}</span>
            <span class="note-card__desc">{{ n.desc }}</span>
            <span class="note-card__meta">{{ n.tagDisplay }} {{ count }} NOTAS</span>
          </span>
        </a>
        {%- endfor -%}
      </div>
      <div class="notas-all">
        <a href="/#notas">Ver todas as notas de estudo →</a>
      </div>
    </section>

    <!-- PUBLICAÇÕES + APPS -->
    <section class="pubapps">

      <div id="publicacoes" class="pubapps__col">
        <div class="section-head">
          <span class="section-head__title">Publicações</span>
          {%- set pubCount = collections.publications | length -%}
          <span class="section-head__num">{% if pubCount < 10 %}0{% endif %}{{ pubCount }} / Books</span>
        </div>
        <div class="pubapps__body">
          {%- for book in collections.publications -%}
          <a href="{{ book.url }}" class="book{% if not loop.last %} book--divider{% endif %}">
            <div class="cover{% if book.cover %} cover--img{% endif %}"{% if book.cover %} style="background-image:url('{{ book.cover }}')"{% endif %}>{% if not book.cover %}<span>capa</span>{% endif %}</div>
            <div>
              {% if book.kind %}<div class="book__kicker">{{ book.kind }}</div>{% endif %}
              <div class="book__title">{{ book.title }}</div>
              {% if book.desc %}<div class="book__desc">{{ book.desc | safe }}</div>{% endif %}
            </div>
          </a>
          {%- endfor -%}
        </div>
      </div>

      <div id="apps" class="pubapps__col">
        <div class="section-head">
          <span class="section-head__title">Apps</span>
          {%- set appCount = collections.tagMap.app | length -%}
          <span class="section-head__num">{% if appCount < 10 %}0{% endif %}{{ appCount }} / Software</span>
        </div>
        <div class="pubapps__body pubapps__body--apps">
          {%- for app in collections.tagMap.app | sortByTitle -%}
          <a href="{{ app.url }}" class="app-row">
            <div class="app-icon{% if app.data.appIcon %} app-icon--img{% endif %}"{% if app.data.appIcon %} style="background-image:url('{{ app.data.appIcon }}')"{% endif %}></div>
            <div class="app-row__text">
              <div class="app-row__name">{{ app.data.title or app.fileSlug }}</div>
              <div class="app-row__desc">{{ app.data.appDesc }}</div>
            </div>
            <span class="app-row__arrow">→</span>
          </a>
          {%- endfor -%}
        </div>
      </div>

    </section>

    {%- elif tagPage -%}

    {{ content | safe }}

    {%- else -%}

    <article class="prose">
      {%- if title -%}
      <h1>{{title}}</h1>
      {%- elif page.fileSlug -%}
      <h1>{{page.fileSlug}}</h1>
      {%- endif -%} {%- if refs -%} 📇 Referências: {{ refs | wikilinks_attr |
      safe }}<br />
      {%- endif -%}{%- if when -%} 📆 Quando: {{ when | wikilinks_attr | safe
      }}<br />
      {%- endif -%}{%- if where -%} 🧭 Onde: {{ where | wikilinks_attr | safe
      }}<br />
      {%- endif -%}{%- if refutes -%} ⚔️ Refuta: {{ refutes | wikilinks_attr |
      safe }}<br />
      {%- endif -%} {%- if source -%} ✍🏻 {{ source | markdown_inline | safe }}<br />
      {%- endif -%} {%- if tags -%} 🔖 {{ tags | linkify_tags | safe }}<br />
      {%- endif -%}{{ content | safe }}
      <div class="article-footer">
        {{ "👨‍💼 " + author if author}}<br />{{ copyright if copyright }}
      </div>
      {% if collections.backlinks[page.url] %}
      <hr />
      <div class="backlinks">
        <h3>Links para esta página</h3>
        <ul>
          {% for link in collections.backlinks[page.url] %}
          <li>
            <a href="{{ link }}">{{ link }}</a>
          </li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
    </article>

    {%- endif -%}
  </main>

  <footer class="site-footer">
    <div>
      <div class="site-footer__name">Reino Eterno</div>
      <div class="site-footer__tag">As coisas que permanecem.</div>
    </div>
    <div class="site-footer__meta">
      © 2026 Reino Eterno<br />Soli Deo Gloria
    </div>
  </footer>
</body>

</html>
